# Base64-encoded raw 32-byte Ed25519 private key seed for the Pi arbiter.
# Generate with: node generate-master-key.js  (from repo root)
MASTER_SECRET_KEY=

# Optional: GitHub Gist beacon for fast peer discovery (~500ms bootstrap).
# Create a secret Gist, then generate a token with gist scope at https://github.com/settings/tokens
GH_GIST_TOKEN=
GH_GIST_ID=
