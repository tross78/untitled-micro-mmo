{
  "name": "untitled-micro-mmo",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "assets:compile": "node scripts/compile-assets.js",
    "assets:gen-frames": "node scripts/gen-animation-frames.js",
    "assets:normalize-palette": "node scripts/normalize-asset-palette.js",
    "build": "esbuild src/main.js --bundle --minify --loader:.wasm=dataurl --external:crypto --outfile=dist/main.js && cp src/index.html dist/index.html && cp src/manifest.json dist/manifest.json && cp src/styles.css dist/styles.css",
    "build:e2e": "npm run build && esbuild src/e2e-entry.js --bundle --minify --loader:.wasm=dataurl --external:crypto --outfile=dist/e2e-main.js && cp src/e2e.html dist/e2e.html",
    "audit:deep": "npm test && npm run test:browser",
    "probe:trackers": "node scripts/probe-trackers.mjs",
    "test": "jest",
    "test:browser": "npm run build:e2e && node scripts/browser-two-peer.mjs",
    "test:browser:live": "npm run build:e2e && node scripts/browser-two-peer-live.mjs",
    "test:ice": "node scripts/browser-ice-test.mjs",
    "test:ice:game": "node scripts/browser-ice-game-test.mjs",
    "lint": "eslint src/**/*.js arbiter/**/*.js scripts/**/*.js",
    "typecheck": "tsc -p tsconfig.json",
    "validate:content": "node scripts/validate-content.js",
    "format": "prettier --write src/*.js",
    "verify": "npm run build && npm test && npm run typecheck && npm run validate:content",
    "diagnose": "bash scripts/diagnose.sh",
    "editor": "npx --yes serve . -l 3001 --no-clipboard & sleep 1 && open http://localhost:3001/tools/editor.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@trystero-p2p/torrent": "^0.23.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
