{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "lib": ["ES2022", "DOM"],
    "types": [],
    "skipLibCheck": true
  },
  "include": [
    "src/app/**/*.js",
    "src/content/**/*.js",
    "src/domain/**/*.js",
    "src/adapters/dom/**/*.js",
    "src/commands/registry.js",
    "scripts/validate-content.js"
  ]
}
